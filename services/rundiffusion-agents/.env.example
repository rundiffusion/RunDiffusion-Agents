# Recommended standalone deploy template for `openclaw-gateway`.
# Use this for the simplest localhost Docker run or for a remote single-service host.
# For the multi-tenant host stack, use the root `.env.example` plus the tenant
# template under `deploy/tenants/templates/tenant.env.example`.
# This assumes the current recommended auth flow:
# native OpenClaw auth for `/openclaw` plus Basic Auth on the operator routes.
# Set the required vars below. Do not add the commented runtime defaults unless you intentionally want to override them.

# Compose helper vars for `docker compose up -d --build`.
# These control host binding and container naming for the standalone package.
# They are not part of the runtime contract inside the container.
STANDALONE_BIND_ADDRESS=127.0.0.1
STANDALONE_PUBLIC_PORT=8080
STANDALONE_CONTAINER_NAME=rd-agents-standalone-local
STANDALONE_DATA_VOLUME=rd-agents-standalone-local-data

# REQUIRED for the recommended standalone deployment.
# `native` keeps OpenClaw's built-in token/device flow.
# `trusted-proxy` is only for deployments that intentionally put `/openclaw` behind nginx Basic Auth.
OPENCLAW_ACCESS_MODE=native

# OPTIONAL for Hermes and later manual provider setup.
# OpenClaw no longer uses provider env vars to seed first-boot model state.
GEMINI_API_KEY=

# STRONGLY RECOMMENDED to set explicitly, even though the runtime can generate one.
# If omitted, the entrypoint generates and persists one in /data/.openclaw/gateway.token.
OPENCLAW_GATEWAY_TOKEN=replace-with-long-random-secret

# REQUIRED for the native device approval flow in the in-box web terminal at `/terminal`.
# Set `TERMINAL_ENABLED=0` only if you intentionally do not want `/terminal`.
TERMINAL_ENABLED=1

# REQUIRED for the proxy-protected operator surfaces.
# The same credentials protect `/dashboard`, `/filebrowser`, `/terminal`, `/hermes`, `/codex`, `/claude`, `/gemini`, and `/pi`.
# In `trusted-proxy` mode, these can be omitted only if you want `/terminal`
# to reuse `OPENCLAW_BASIC_AUTH_*` via fallback.
TERMINAL_BASIC_AUTH_USERNAME=operator-firstinitial-lastname
TERMINAL_BASIC_AUTH_PASSWORD=replace-with-separate-terminal-password-MUST-BE-STRONG

# OPTIONAL dashboard route overrides.
# `/dashboard` is the operator landing page for the sibling tools plus a few helper utilities.
# It reuses the same Basic Auth credentials as `/terminal` and `/filebrowser`.
# DASHBOARD_BASE_URL=/dashboard
# DASHBOARD_API_BASE_URL=/dashboard-api
# DASHBOARD_DATA_DIR=/data/.dashboard
# DASHBOARD_PREFERENCES_PATH=/data/.dashboard/preferences.json

# OpenClaw now boots with only the wrapper-owned gateway/workspace config.
# Configure models and provider auth inside OpenClaw after first boot so the
# resulting state on disk reflects the upstream onboarding flow.
#
# This image no longer rewrites model state on boot. Manage startup/default
# models through the host control plane or inside OpenClaw directly.

# OPTIONAL dedicated Hermes route.
# `HERMES_ENABLED=1` exposes `/hermes` as the quick drop-in Hermes experience.
# `/terminal` remains a plain shell for maintenance and device approval.
HERMES_ENABLED=1
HERMES_HOME=/data/.hermes

# OPTIONAL browser-native Hermes WebUI route.
# `HERMES_WEBUI_ENABLED=1` exposes `/hermes-webui` beside the existing `/hermes`
# terminal route. It reuses `HERMES_HOME`, `HERMES_WORKSPACE_DIR`, and the
# operator Basic Auth credentials. Leave `HERMES_WEBUI_PASSWORD` blank when the
# route is already protected by gateway Basic Auth.
HERMES_WEBUI_ENABLED=0
HERMES_WEBUI_PASSWORD=

# OPTIONAL dedicated Hermes key.
# If omitted, Hermes uses `GEMINI_API_KEY` with Google's OpenAI-compatible endpoint.
HERMES_OPENAI_API_KEY=
HERMES_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
HERMES_MODEL_NAME=gemini-3-flash-preview

# OPTIONAL dedicated Codex route.
# `CODEX_ENABLED=1` exposes `/codex` as the quick drop-in Codex CLI experience.
# By default this route is not pre-authenticated; the user logs in inside Codex
# and the session persists in `CODEX_HOME`. Set `CODEX_OPENAI_API_KEY` only if
# you intentionally want non-interactive pre-auth.
CODEX_ENABLED=1
CODEX_HOME=/data/.codex
CODEX_OPENAI_API_KEY=

# OPTIONAL dedicated Claude Code route.
# `CLAUDE_ENABLED=1` exposes `/claude` as the quick drop-in Claude Code experience.
# By default this route is not pre-authenticated; the user logs in inside Claude
# Code and the session persists in `CLAUDE_HOME`. Set `CLAUDE_ANTHROPIC_API_KEY`
# only if you intentionally want non-interactive pre-auth.
CLAUDE_ENABLED=1
CLAUDE_HOME=/data/.claude
CLAUDE_ANTHROPIC_API_KEY=

# OPTIONAL dedicated Gemini CLI route.
# `GEMINI_ENABLED=1` exposes `/gemini` as the quick drop-in Gemini CLI experience.
# By default this route is not pre-authenticated; the user logs in inside Gemini
# and the session persists in `GEMINI_HOME`. Set `GEMINI_CLI_API_KEY` only if
# you intentionally want non-interactive pre-auth.
GEMINI_ENABLED=0
GEMINI_HOME=/data/.gemini
GEMINI_CLI_API_KEY=

# OPTIONAL dedicated Pi coding agent route.
# `PI_ENABLED=1` exposes `/pi` as the quick drop-in Pi coding agent experience.
# By default this route is not pre-authenticated; the user logs in inside Pi
# and the session persists in `PI_CODING_AGENT_DIR`. Set `PI_*` provider keys
# only if you intentionally want non-interactive pre-auth.
PI_ENABLED=1
PI_HOME=/data/.pi
PI_CODING_AGENT_DIR=/data/.pi/agent
PI_OPENAI_API_KEY=
PI_ANTHROPIC_API_KEY=
PI_GEMINI_API_KEY=
PI_OPENROUTER_API_KEY=

# OPTIONAL workspace overrides for operator routes.
# By default `/terminal` uses `OPENCLAW_WORKSPACE_DIR=/data/workspaces/openclaw`
# and `/hermes` uses `HERMES_WORKSPACE_DIR=/data/workspaces/hermes`.
# `/codex`, `/claude`, `/gemini`, and `/pi` each get their own tool workspace and also
# receive `openclaw-workspace` and `hermes-workspace` shortcuts for targeted fixes.
# Set any of these only if you intentionally want a different layout.
# OPENCLAW_WORKSPACE_DIR=/data/workspaces/openclaw
# HERMES_WORKSPACE_DIR=/data/workspaces/hermes
# CODEX_WORKSPACE_DIR=/data/workspaces/codex
# CLAUDE_WORKSPACE_DIR=/data/workspaces/claude
# GEMINI_WORKSPACE_DIR=/data/workspaces/gemini
# PI_WORKSPACE_DIR=/data/workspaces/pi

# OPTIONAL browser terminal rendering overrides.
# These tune the shared ttyd/xterm.js stack used by `/terminal`, `/hermes`,
# `/codex`, `/claude`, `/gemini`, and `/pi`.
# The image defaults are chosen for better browser rendering and truecolor.
# TTYD_CLIENT_RENDERER_TYPE=dom
# TTYD_CLIENT_FONT_FAMILY=ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace
# TTYD_CLIENT_FONT_SIZE=14
# TTYD_CLIENT_SCROLLBACK=50000
# TTYD_TERMINAL_TYPE=xterm-256color
# TERMINAL_LANG=C.UTF-8
# TERMINAL_LC_ALL=C.UTF-8
# TERMINAL_COLORTERM=truecolor

# OPTIONAL OpenRouter key.
# Keeps OpenRouter available in `/hermes` without pre-shaping OpenClaw state.
OPENROUTER_API_KEY=

# `/filebrowser` now uses the same Basic Auth as `/terminal`, `/hermes`, `/codex`,
# `/claude`, `/gemini`, and `/pi`. There is no separate FileBrowser login to configure.

# OPTIONAL when your host injects `RAILWAY_PUBLIC_DOMAIN` and it matches the browser origin.
# Set exact browser origins as a comma-separated list for custom domains, multiple origins,
# or if the browser shows `origin not allowed`.
# For the recommended localhost path, set both loopback origins explicitly.
# For vanilla native `/openclaw`, use localhost or HTTPS. Plain HTTP non-loopback
# origins are not a supported device-auth path.
# Example:
# OPENCLAW_CONTROL_UI_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,https://openclaw.example.com
# If omitted, the runtime derives an origin from `RAILWAY_PUBLIC_DOMAIN` when that env var exists.
OPENCLAW_CONTROL_UI_ALLOWED_ORIGINS=

# OPTIONAL only when `OPENCLAW_ACCESS_MODE=trusted-proxy`.
# These are no longer required for the recommended native/device-binding flow.
OPENCLAW_BASIC_AUTH_USERNAME=operator-firstinitial-lastname
OPENCLAW_BASIC_AUTH_PASSWORD=replace-with-separate-password

# OPTIONAL later-only provider envs.
# Leave these unset for the clean vanilla boot. Add them later only if you
# intentionally want env-backed auth outside the manual onboarding flow.
# OPENAI_API_KEY=
# MOONSHOT_API_KEY=

# Runtime defaults below are already provided by the image and platform config.
# Do not set them unless you intentionally want to override the deployment layout.
# PORT=8080
# OPENCLAW_INTERNAL_PORT=8081
# OPENCLAW_GATEWAY_BIND=loopback
# OPENCLAW_TTY_TERM_PROGRAM=OpenClawTTYD
# Advanced Control UI override flags exist in the runtime but are intentionally
# omitted from this public template. The recommended native path is localhost or
# HTTPS, not insecure-auth or device-auth bypass flags.
# FILEBROWSER_INTERNAL_PORT=8082
# TTYD_TERMINAL_TYPE=xterm-256color
# TTYD_CLIENT_RENDERER_TYPE=dom
# TTYD_CLIENT_FONT_FAMILY=ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace
# TTYD_CLIENT_FONT_SIZE=14
# TTYD_CLIENT_SCROLLBACK=50000
# TERMINAL_LANG=C.UTF-8
# TERMINAL_LC_ALL=C.UTF-8
# TERMINAL_COLORTERM=truecolor
# OPENCLAW_STATE_DIR=/data/.openclaw
# OPENCLAW_WORKSPACE_DIR=/data/workspaces/openclaw
# OPENCLAW_CONFIG_PATH=/data/.openclaw/openclaw.json
# NODE_COMPILE_CACHE=/var/tmp/openclaw-compile-cache
# OPENCLAW_NO_RESPAWN=0
# The wrapper supervises OpenClaw in this image, so full-process gateway restarts
# are expected and should not tear down the whole container.
# Set OPENCLAW_NO_RESPAWN=1 only if you intentionally want container lifecycle
# tied to the initial OpenClaw gateway process.
# FILEBROWSER_BASE_URL=/filebrowser
# TERMINAL_INTERNAL_PORT=8083
# TERMINAL_BASE_URL=/terminal
# TERMINAL_SESSION_NAME=openclaw
# HERMES_INTERNAL_PORT=8090
# HERMES_BASE_URL=/hermes
# HERMES_SESSION_NAME=hermes
# HERMES_WORKSPACE_DIR=/data/workspaces/hermes
# HERMES_WEBUI_INTERNAL_PORT=8095
# HERMES_WEBUI_BASE_URL=/hermes-webui
# HERMES_WEBUI_HOST=127.0.0.1
# HERMES_WEBUI_STATE_DIR=/data/.hermes/webui
# HERMES_WEBUI_DEFAULT_WORKSPACE=/data/workspaces/hermes
# HERMES_WEBUI_AGENT_DIR=/opt/hermes-src
# HERMES_WEBUI_PYTHON=/opt/hermes-venv/bin/python
# HERMES_WEBUI_INFERENCE_PROVIDER=auto
# CODEX_INTERNAL_PORT=8091
# CODEX_BASE_URL=/codex
# CODEX_SESSION_NAME=codex
# CODEX_WORKSPACE_DIR=/data/workspaces/codex
# CLAUDE_INTERNAL_PORT=8092
# CLAUDE_BASE_URL=/claude
# CLAUDE_SESSION_NAME=claude
# CLAUDE_WORKSPACE_DIR=/data/workspaces/claude
# GEMINI_INTERNAL_PORT=8093
# GEMINI_BASE_URL=/gemini
# GEMINI_SESSION_NAME=gemini
# GEMINI_WORKSPACE_DIR=/data/workspaces/gemini
# PI_INTERNAL_PORT=8096
# PI_BASE_URL=/pi
# PI_SESSION_NAME=pi
# PI_HOME=/data/.pi
# PI_CODING_AGENT_DIR=/data/.pi/agent
# PI_WORKSPACE_DIR=/data/workspaces/pi
# FILEBROWSER_DATA_DIR=/data/.filebrowser
# FILEBROWSER_CONFIG_PATH=/tmp/filebrowser-config.yaml
# FILEBROWSER_DATABASE_PATH=/data/.filebrowser/database.db
# FILEBROWSER_CACHE_DIR=/data/.filebrowser/cache
# DASHBOARD_INTERNAL_PORT=8094
# DASHBOARD_BASE_URL=/dashboard
# DASHBOARD_API_BASE_URL=/dashboard-api
# DASHBOARD_DATA_DIR=/data/.dashboard
# DASHBOARD_PREFERENCES_PATH=/data/.dashboard/preferences.json
