# Shared host configuration for the RunDiffusion Agents multi-tenant host stack.
# Copy this to `.env` and adjust the values for your host.
# For the standalone localhost path, use `services/rundiffusion-agents/.env.example` instead.

COMPOSE_PROJECT_NAME=rundiffusion-agents
BASE_DOMAIN=agents.example.com

# Ingress mode:
#   local      = bind Traefik for same-host or LAN/private-network access
#   direct     = expose Traefik directly on a VM/server IP and point DNS at it
#   cloudflare = keep Traefik local and put cloudflared in front
# Native `/openclaw` still requires HTTPS or localhost. Plain HTTP LAN hostnames
# are fine for the shared host stack, but they are not a supported vanilla
# device-auth path for OpenClaw.
INGRESS_MODE=local

# Public/browser scheme used when generating tenant allowed origins.
# The tenant helpers write the exact browser origin for OpenClaw Control UI,
# including :TRAEFIK_HTTP_PORT when Traefik is not on 80/443.
# Leave blank to auto-pick:
#   cloudflare -> https
#   local/direct -> http
# Auto-picking `http` for local/direct does not change the native OpenClaw rule:
# non-loopback HTTP origins still need HTTPS if you want vanilla device approval.
PUBLIC_URL_SCHEME=

# Host paths should live outside the git checkout.
# Recommended layout:
#   /srv/rundiffusion-agents/data
#   /srv/rundiffusion-agents/secrets/tenants
DATA_ROOT=/srv/rundiffusion-agents/data
TENANT_ENV_ROOT=/srv/rundiffusion-agents/secrets/tenants
TENANT_CONTROL_PLANE_CONFIG_PATH=/srv/rundiffusion-agents/secrets/tenants/control-plane.yml

# Shared host ingress.
TRAEFIK_BIND_ADDRESS=127.0.0.1
TRAEFIK_HTTP_PORT=38080
TRAEFIK_NETWORK=rundiffusion-public
TRAEFIK_IMAGE=traefik:v3.4@sha256:06ddf61ee653caf4f4211a604e657f084f4727f762c16f826c97aafbefcb279e
TRAEFIK_LOG_LEVEL=INFO

# Cloudflare Tunnel is optional and stays host-managed outside Docker Compose.
# Only required when INGRESS_MODE=cloudflare.
CLOUDFLARE_HOSTNAME_MODE=wildcard
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_CREDENTIALS_FILE=
CLOUDFLARE_TUNNEL_METRICS=127.0.0.1:20241
CLOUDFLARED_LAUNCHD_LABEL=com.rundiffusion.agents.cloudflared

# Deploy behavior.
DEPLOY_MODE=build
AUTO_ROLLBACK=1
IMAGE_REPOSITORY=local/openclaw-gateway
# Default OpenClaw npm version to bake into new gateway images when DEPLOY_MODE=build; tenant `openclawVersion` and then `./scripts/deploy.sh --openclaw-version ...` can override it.
# Override one deploy with: ./scripts/deploy.sh --tenant <slug> --openclaw-version 2026.4.15
OPENCLAW_VERSION=2026.4.15
GATEWAY_IMAGE_TAG=
# Tool versions baked into gateway images. Bump intentionally; avoid floating
# `@latest` in production builds.
NODE_IMAGE_REF=docker.io/library/node:22-bookworm-slim@sha256:d415caac2f1f77b98caaf9415c5f807e14bc8d7bdea62561ea2fef4fbd08a73c
FILEBROWSER_IMAGE_REF=ghcr.io/gtsteffaniak/filebrowser:stable-slim@sha256:8e6f7d32f5f0b7a40cb3a80197ef27088f01828a132f5bfed337d77b10e0f1e2
CODEX_CLI_VERSION=0.125.0
CLAUDE_CODE_VERSION=2.1.119
GEMINI_CLI_VERSION=0.39.1
PI_CODING_AGENT_VERSION=0.70.5
HOMEBREW_INSTALL_REF=d683ebc428169a5e0d60959e48a4c35d6f23ddd9
HOMEBREW_BREW_REF=5.1.8
HERMES_REF=v2026.4.23
HERMES_WEBUI_REF=v0.50.236
# Optional Docker build overrides. Leave blank to use Docker's active context,
# default builder, and native platform. On hosts that need Docker Desktop's
# classic context workaround, set these explicitly in `.env`.
DOCKER_BUILD_CONTEXT=
DOCKER_BUILDER=
DOCKER_BUILD_PLATFORM=

# Resource guardrails for each tenant stack.
TENANT_MEMORY_RESERVATION=1536m
TENANT_MEMORY_LIMIT=3072m
TENANT_PIDS_LIMIT=512
# Container runtime profile for the shared openclaw-gateway tenant image.
# Start with tool-userns. Escalate to privileged only if `unshare -U true`
# still fails inside a redeployed tenant container.
TENANT_CONTAINER_SECURITY_PROFILE=tool-userns
MAX_ALWAYS_ON_TENANTS=8

# Backup and release metadata live under DATA_ROOT by default.
BACKUP_ROOT=
RELEASE_ROOT=
