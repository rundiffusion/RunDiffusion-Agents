# Copy this to a tenant-specific env file outside git.
# Example path: /srv/rundiffusion-agents/secrets/tenants/tenant-a.env
# This template is for the multi-tenant host stack. For a single-tenant local
# or remote run, use `services/rundiffusion-agents/.env.example` instead.

TENANT_SLUG=tenant-a
TENANT_HOSTNAME=tenant-a.example.com
# Use the exact browser origin, including the port when Traefik is not on 80/443.
# For vanilla native `/openclaw`, that browser origin should be HTTPS unless you
# are on `localhost`. Plain HTTP LAN hostnames are not a supported native path.
OPENCLAW_CONTROL_UI_ALLOWED_ORIGINS=https://tenant-a.example.com

OPENCLAW_ACCESS_MODE=native
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-token

TERMINAL_ENABLED=1
TERMINAL_BASIC_AUTH_USERNAME=tenant-a-operator
TERMINAL_BASIC_AUTH_PASSWORD=replace-with-a-strong-password

HERMES_ENABLED=1
CODEX_ENABLED=1
CLAUDE_ENABLED=1
CLAUDE_INTERNAL_PORT=8192
GEMINI_ENABLED=0

# ---------------------------------------------------------------------------
# Hermes provider configuration
# ---------------------------------------------------------------------------
# Three modes, pick one:
#
# 1) Gemini default (zero-config): set HERMES_OPENAI_API_KEY (or GEMINI_API_KEY)
#    and leave the *_BASE_URL / *_MODEL_NAME blank. The gateway wires Hermes
#    to Google's OpenAI-compatible endpoint with gemini-3-flash-preview.
#
# 2) Other OpenAI-compatible provider (Moonshot/Kimi, DeepSeek, Together,
#    OpenRouter as a proxy, etc.): set HERMES_OPENAI_BASE_URL to the provider's
#    /v1 endpoint, HERMES_MODEL_NAME to the model id, HERMES_OPENAI_API_KEY
#    to the API key.
#    Example (Moonshot):
#      HERMES_OPENAI_BASE_URL=https://api.moonshot.ai/v1
#      HERMES_MODEL_NAME=kimi-k2.6
#
# 3) Native Hermes provider picker: set HERMES_PROVIDER_PASSTHROUGH=1.
#    The gateway leaves /data/.hermes/ alone; the operator picks the
#    provider and enters credentials via `hermes model` in the tenant
#    terminal. This unlocks Hermes's full provider list (Nous Portal,
#    Kimi, Z.AI, MiniMax, OpenRouter, custom endpoints, etc.) and lets
#    Hermes self-update its provider catalog with future releases.
HERMES_OPENAI_BASE_URL=
HERMES_MODEL_NAME=
HERMES_PROVIDER_PASSTHROUGH=0

# Optional: run `hermes gateway` as a long-lived daemon inside the tenant
# container for messaging platforms (Telegram, Discord, Slack, WhatsApp)
# and cron scheduling. Without this, platform tokens configured via
# `hermes model` or /data/.hermes/.env are inert — no messages flow.
# The gateway image ships the `messaging` Hermes extra by default; set
# to 1 after you have configured at least one platform token.
HERMES_GATEWAY_ENABLED=0

# Optional provider credentials. Keep these tenant-specific.
GEMINI_API_KEY=
HERMES_OPENAI_API_KEY=
CODEX_OPENAI_API_KEY=
CLAUDE_ANTHROPIC_API_KEY=
GEMINI_CLI_API_KEY=
OPENROUTER_API_KEY=

# Optional per-tenant Tailscale settings. When enabled, the deploy tooling mounts
# /dev/net/tun, adds NET_ADMIN/NET_RAW, and persists /var/lib/tailscale.
TAILSCALE_ENABLED=0
TAILSCALE_AUTHKEY=
TAILSCALE_HOSTNAME=
